NODE_ENV=development
AUTH_BASE_URL_V2=http://host.docker.internal:8081/v2

# Meeting recording configuration
MAX_RECORDING_DURATION_MINUTES=180
MEETING_INACTIVITY_MINUTES=15
INACTIVITY_DETECTION_START_DELAY_MINUTES=5
RECORDING_VIDEO_BITRATE_BPS=4000000
RECORDING_AUDIO_BITRATE_BPS=192000
RECORDING_CHUNK_DURATION_MS=10000
GENERATE_MP4_ARTIFACT=true

# Manager transcription pipeline
# Engine: offline | azure | gemini | none
TRANSCRIPTION_MODE=offline
OFFLINE_TRANSCRIPTION_LANGUAGE=en
OFFLINE_MAX_SPEAKERS=6
WHISPER_CPP_USE_GPU=false
WHISPER_CPP_GPU_LAYERS=35

# Azure Speech (required when TRANSCRIPTION_MODE=azure)
AZURE_SPEECH_REGION=
AZURE_SPEECH_ENDPOINT=
AZURE_SPEECH_KEY=
AZURE_SPEECH_LOCALE=en-AU
AZURE_SPEECH_ENABLE_DIARIZATION=true
AZURE_SPEECH_DIARIZATION_MAX_SPEAKERS=6
AZURE_SPEECH_FALLBACK_TO_OFFLINE=true

# GCP bucket configuration for uploading debugging screenshots
GCP_ACCESS_KEY_ID=
GCP_SECRET_ACCESS_KEY=
GCP_MISC_BUCKET=
GCP_MISC_BUCKET_FOLDER=meeting-bot
GCP_DEFAULT_REGION=

# For patching the status or logs of bots
SCREENAPP_BACKEND_SERVICE_API_KEY=

# Redis
REDIS_CONSUMER_ENABLED=false
REDIS_QUEUE_NAME=jobs:meetbot:list
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=

# Uploader
UPLOADER_FILE_EXTENSION=.webm
UPLOADER_TYPE=s3

# S3 compatible storage for recording upload
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=
S3_ENDPOINT=
S3_BUCKET_NAME=
S3_USE_MINIO_COMPATIBILITY=false

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=1.0
